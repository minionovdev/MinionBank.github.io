<!-- Мнемоника после регистрации -->
<div id="mnemonicPage" class="card hidden">
  <h2>Сохраните свои 24 слова восстановления</h2>
  <p>Если вы потеряете доступ к кошельку, эти слова помогут восстановить баланс:</p>
  <div id="mnemonicWords" class="mnemonic"></div>
  <button onclick="goToMain()">Продолжить</button>
</div>

<!-- Главный экран -->
<div id="mainPage" class="hidden">
  <div class="card" id="balanceCard">
    <h2 id="userName">Не вошли в систему</h2>
    <p id="userBalance">Баланс: -</p>
    <p id="userAddress">Адрес: -</p>
  </div>

  <div class="buttons">
    <button class="mine" onclick="showMinePage()">⛏️ Майнить MINION</button>
    <button class="send" onclick="showSendForm()">📤 Отправить MINION</button>
    <button class="custom" onclick="showCustomForm()">🏷️ Купить кастомный адрес</button>
  </div>
