<!-- Форма отправки -->
<div id="sendForm" class="card hidden">
  <h3>Отправка MINION</h3>
  <input type="text" id="recipientInput" placeholder="Адрес получателя">
  <input type="number" id="amountInput" placeholder="Сумма">
  <button class="send" onclick="sendTokens()">Отправить</button>
</div>

<!-- Форма кастомного адреса -->
<div id="customForm" class="card hidden">
  <h3>Купить кастомный адрес</h3>
  <p>Предложения дешевле: <span id="cheapOffer">minion1.minion.bank, minion2.minion.bank</span></p>
  <input type="text" id="customInput" placeholder="Имя для адреса">
  <button class="custom" onclick="buyCustomAddress()">Купить</button>
</div>

<!-- Страница майнинга -->
<div id="minePage" class="card hidden">
  <h3>Майнить MINION</h3>
  <p>Нажмите на круг 100 раз чтобы получить токены. Энергия перезаряжается 10 минут после использования</p>
  <div id="tapArea">💎</div>
  <p>Нажато: <span id="tapCount">0</span>/100</p>
  <button onclick="exitMine()">Вернуться</button>
</div>

