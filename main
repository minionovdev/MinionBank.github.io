<script>
let users={};
let currentUser=null;
let MINE_REWARD=10;
let CUSTOM_ADDRESS_COST=1000;
let taps=0;
let energyAvailable=true;
const energyRechargeTime=10*60*1000;

// ----------------------
// Переключение форм
// ----------------------
function showRegister(){document.getElementById("loginForm").classList.add("hidden");document.getElementById("registerForm").classList.remove("hidden");document.getElementById("formTitle").innerText="Регистрация";}
function showLogin(){document.getElementById("registerForm").classList.add("hidden");document.getElementById("loginForm").classList.remove("hidden");document.getElementById("formTitle").innerText="Войти";}

// ----------------------
// Регистрация / вход
// ----------------------
function registerUser(){
  const name=document.getElementById("regName").value.trim();
  const email=document.getElementById("regEmail").value.trim();
  const password=document.getElementById("regPassword").value;
  if(!name||!email||!password){alert("Заполните все поля");return;}
  if(users[name]){alert("Пользователь уже существует");return;}
  users[name]={balance:100,lastMine:null,custom_address:null,email,password};
  currentUser=name;
  generateMnemonic();
}
function loginUser(){
  const name=document.getElementById("loginName").value.trim();
  const password=document.getElementById("loginPassword").value;
  if(!users[name]||users[name].password!==password){alert("Неверные данные");return;}
  currentUser=name;
  document.getElementById("loginPage").classList.add("hidden");
  document.getElementById("mainPage").classList.remove("hidden");
  updateUI();
}

// ----------------------
// Мнемоника
// ----------------------
function generateMnemonic(){
  const words="apple banana cat dog elephant frog grape hat igloo joker kite lion moon nut orange panda queen rabbit sun tiger umbrella violin wolf xray yellow zebra".split(" ");
  let mnemonic=[];
  for(let i=0;i<24;i++){mnemonic.push(words[Math.floor(Math.random()*words.length)]);}
  document.getElementById("mnemonicWords").innerText=mnemonic.join(" ");
  document.getElementById("loginPage").classList.add("hidden");
  document.getElementById("mnemonicPage").classList.remove("hidden");
}
function goToMain(){document.getElementById("mnemonicPage").classList.add("hidden");document.getElementById("mainPage").classList.remove("hidden");updateUI();}

// ----------------------
// Обновление баланса
// ----------------------
function updateUI(){
  if(currentUser){
    document.getElementById('userName').innerText=currentUser;
    document.getElementById('userBalance').innerText="Баланс: "+users[currentUser].balance+" MINION";
    document.getElementById('userAddress').innerText="Адрес: "+(users[currentUser].custom_address||"-");
  }
}

// ----------------------
// Отправка токенов
// ----------------------
function showSendForm(){hideAll();document.getElementById("sendForm").classList.remove("hidden");}
function sendTokens(){
  const recipient=document.getElementById("recipientInput").value.trim();
  const amount=parseInt(document.getElementById("amountInput").value);
  if(!recipient||!amount){alert("Введите адрес и сумму");return;}
  if(!users[recipient]){alert("Получатель не найден");return;}
  if(users[currentUser].balance<amount){alert("Недостаточно средств");return;}
  users[currentUser].balance-=amount;
  users[recipient].balance+=amount;
  updateUI();
  alert("Отправлено "+amount+" MINION пользователю "+recipient);
  hideAll();
}

// ----------------------
// Кастомные адреса
// ----------------------
function showCustomForm(){hideAll();document.getElementById("customForm").classList.remove("hidden");}
function buyCustomAddress(){
  const name=document.getElementById("customInput").value.trim();
  if(!name){alert("Введите имя");return;}
  const full=name+".minion.bank";
  for(let u in users){if(users[u].custom_address==full){alert("Адрес занят");return;}}
  if(users[currentUser].balance<CUSTOM_ADDRESS_COST){alert("Недостаточно средств");return;}
  users[currentUser].balance-=CUSTOM_ADDRESS_COST;
  users[currentUser].custom_address=full;
  updateUI();
  alert("Вы купили адрес "+full);
  hideAll();
}

// ----------------------
// Майнинг
// ----------------------
function showMinePage(){
  if(!energyAvailable){alert("Энергия перезаряжается. Подождите.");return;}
  hideAll();
  document.getElementById("minePage").classList.remove("hidden");
  taps=0;
  document.getElementById("tapCount").innerText="0";
}
document.getElementById("tapArea").addEventListener("click",()=>{
  if(!energyAvailable||taps>=100) return;
  taps++;
  document.getElementById("tapCount").innerText=taps;
  if(taps>=100){
    users[currentUser].balance+=MINE_REWARD;
    updateUI();
    alert("Майнинг завершен! Вы получили "+MINE_REWARD+" MINION");
    energyAvailable=false;
    setTimeout(()=>{energyAvailable=true;alert("Энергия восстановлена!");},10*60*1000);
  }
});
function exitMine(){hideAll();document.getElementById("mainPage").classList.remove("hidden");}

// ----------------------
// Скрыть все формы
// ----------------------
function hideAll(){
  document.getElementById("sendForm").classList.add("hidden");
  document.getElementById("customForm").classList.add("hidden");
  document.getElementById("minePage").classList.add("hidden");
}

// ----------------------
// Тестовый пользователь
// ----------------------
users["Alice"]={balance:100,lastMine:null,custom_address:null,email:"alice@test.com",password:"1234"};

</script>
</body>
</html>
